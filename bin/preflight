#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/lib.sh"
mcc_ensure_repo_root

MODE="whole-files"
BASE_REF=""
declare -a INPUT_TARGETS=()
declare -a TARGETS=()
declare -a FILTERED_TARGETS=()
AUTO_DETECTED=false
HAS_INPUT_TARGETS=false

function usage() {
  cat <<USAGE
Usage: ./bin/preflight [--changed-lines|--diff] [--base-ref <ref>] [path...]

Default behaviour:
- new files: lint whole file
- modified tracked files: lint whole file

Changed-lines mode:
- new or untracked files: lint whole file
- modified tracked files: report PHPCS only on changed lines

Examples:
  ./bin/preflight
  ./bin/preflight public/local/example
  ./bin/preflight --changed-lines
  ./bin/preflight --changed-lines --base-ref origin/main public/mod/forum/lib.php
USAGE
}

function preflight_should_lint() {
  local target="$1"

  if [[ -d "${MOODLE_DIR}/${target}" ]]; then
    return 0
  fi

  case "${target}" in
    *.php|*.inc)
      return 0
      ;;
  esac

  return 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --changed-lines|--diff)
      MODE="changed-lines"
      shift
      ;;
    --base-ref)
      [[ $# -ge 2 ]] || mcc_fail "Missing value for --base-ref"
      BASE_REF="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      INPUT_TARGETS+=("$1")
      HAS_INPUT_TARGETS=true
      shift
      ;;
  esac
done

if [[ "${HAS_INPUT_TARGETS}" == "true" ]]; then
  TARGETS=("${INPUT_TARGETS[@]}")
fi

if [[ ${#TARGETS[@]} -eq 0 ]]; then
  AUTO_DETECTED=true
  while IFS= read -r target; do
    [[ -n "${target}" ]] && TARGETS+=("${target}")
  done < <("$(dirname "$0")/changed-files" "${BASE_REF}")
  while IFS= read -r target; do
    [[ -n "${target}" ]] && TARGETS+=("${target}")
  done < <(mcc_untracked_files_in_worktree)
fi

if [[ "${AUTO_DETECTED}" == "true" ]]; then
  for target in "${TARGETS[@]}"; do
    if preflight_should_lint "${target}"; then
      FILTERED_TARGETS+=("${target}")
    fi
  done
  TARGETS=()
  if [[ ${#FILTERED_TARGETS[@]} -gt 0 ]]; then
    TARGETS=("${FILTERED_TARGETS[@]}")
  fi
fi

if [[ ${#TARGETS[@]} -eq 0 ]]; then
  if [[ "${AUTO_DETECTED}" == "true" ]]; then
    echo "No PHPCS-relevant files to lint."
  else
    echo "No files to lint."
  fi
  exit 0
fi

if [[ "${MODE}" == "changed-lines" ]]; then
  echo "PHPCS scope: changed lines for tracked files, whole files for new or untracked files."
  if [[ -n "${BASE_REF}" ]]; then
    echo "Base ref: ${BASE_REF}"
  fi
  if [[ "${HAS_INPUT_TARGETS}" == "true" ]]; then
    echo "Requested targets:"
    printf '  %s\n' "${INPUT_TARGETS[@]}"
  elif [[ ${#TARGETS[@]} -gt 0 ]]; then
    echo "Auto-detected PHPCS targets:"
    printf '  %s\n' "${TARGETS[@]}"
  fi

  declare -a CHANGED_CMD=("$(dirname "$0")/phpcs-changed")
  if [[ -n "${BASE_REF}" ]]; then
    CHANGED_CMD+=("--base-ref" "${BASE_REF}")
  fi
  if [[ "${HAS_INPUT_TARGETS}" == "true" ]]; then
    CHANGED_CMD+=("${INPUT_TARGETS[@]}")
  fi
  "${CHANGED_CMD[@]}"
  exit 0
fi

echo "PHPCS scope: whole files."
if [[ ${#TARGETS[@]} -gt 0 ]]; then
  if [[ "${AUTO_DETECTED}" == "true" ]]; then
    echo "Auto-detected PHPCS targets:"
  else
    echo "Requested PHPCS targets:"
  fi
  printf '  %s\n' "${TARGETS[@]}"
fi

"$(dirname "$0")/phpcs" "${TARGETS[@]}"

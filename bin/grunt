#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/lib.sh"
mcc_ensure_repo_root

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<USAGE
Usage: ./bin/grunt [grunt-args...]

Runs the Moodle Grunt tool from the parent Moodle checkout using the local
Node dependencies. This is intended for targeted JavaScript/CSS builds, not
for replacing the native Grunt task surface.

Examples:
  ./bin/grunt amd --files=public/mod/assign/amd/src/view.js
  ./bin/grunt amd --root=public/mod/assign
  ./bin/grunt css --root=public/theme/boost

Prefer the narrowest practical build scope. For Moodle AMD work, edit amd/src
files and rebuild the corresponding generated amd/build artifacts rather than
editing built files directly.
USAGE
  exit 0
fi

mcc_exec_moodle_grunt "$@"

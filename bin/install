#!/usr/bin/env bash
set -euo pipefail
source "$(dirname "$0")/lib.sh"

SITE_FULLNAME="${SITE_FULLNAME:-Moodle Master}"
SITE_SHORTNAME="${SITE_SHORTNAME:-docker_moodle}"
SITE_SUMMARY="${SITE_SUMMARY:-Moodle dev site}"
ADMIN_USER="${ADMIN_USER:-admin}"
ADMIN_PASS="${ADMIN_PASS:-test}"
ADMIN_EMAIL="${ADMIN_EMAIL:-admin@example.com}"

mcc_ensure_moodle_checkout
INSTALL_CLI="$(mcc_install_cli_path)" || mcc_fail "Missing install CLI in Moodle checkout: $(mcc_file_hint "admin/cli/install_database.php")"

mcc_exec_web php "${INSTALL_CLI}" \
  --agree-license \
  --fullname="${SITE_FULLNAME}" \
  --shortname="${SITE_SHORTNAME}" \
  --summary="${SITE_SUMMARY}" \
  --adminuser="${ADMIN_USER}" \
  --adminpass="${ADMIN_PASS}" \
  --adminemail="${ADMIN_EMAIL}" \
  "$@"

# Copy this file to .claude.env in the repository root and adjust for your machine.
# Run all wrapper commands from the repository root, for example:
#   cd ~/projects/moodle/claude
#   ./bin/doctor
#
# Chrome MCP, Firefox MCP, and Atlassian MCP are configured in the Claude Code client,
# not in this file.
#
# Author metadata for generated Moodle file headers lives in a separate local
# file:
#   ./.claude.identity
# Start by copying .claude.identity.example.

# Absolute path to the Moodle LMS checkout that this harness should target.
# This repository is expected to live inside that checkout as ./claude.
MOODLE_DIR="$HOME/projects/moodle"

# Absolute path to the moodle-docker checkout used to run the containers.
MOODLE_DOCKER_DIR="$HOME/projects/moodle-docker"

# Absolute path to the sibling agentic orchestrator checkout used for
# discovery-first Moodle tasks.
AGENTIC_ORCHESTRATOR_DIR="$HOME/projects/agentic_orchestrator"

# Optional override for the local author metadata file used for generated
# Moodle file headers/docblocks.
# MCC_IDENTITY_FILE="$HOME/projects/moodle/claude/.claude.identity"

# The orchestrator requires its own local config at:
#   ${AGENTIC_ORCHESTRATOR_DIR}/config.local.toml
# Manual verification: run the following from AGENTIC_ORCHESTRATOR_DIR and confirm
# it returns READY or DEGRADED (not NOT_READY) before relying on orchestrator results:
#   PYTHONPATH=src python3 -m agentic_orchestrator.cli verify --config ./config.local.toml
# Use install-siblings to bootstrap all sibling tools in one step:
#   PYTHONPATH=src python3 -m agentic_orchestrator.cli install-siblings \
#     --install-root ~/projects/agentic-moodle-tools --write-config ./config.local.toml

# Optional override if moodle-docker-compose lives somewhere other than
# ${MOODLE_DOCKER_DIR}/bin.
# MOODLE_DOCKER_BIN_DIR="$HOME/projects/moodle-docker/bin"

# Docker Compose service name for the Moodle PHP/web container.
WEBSERVER_SERVICE="webserver"

# Container user for commands that should avoid creating root-owned files on the
# mounted Moodle checkout. The default matches common moodle-docker setups.
WEBSERVER_USER="www-data"

# Optional host-side PHPCS binary overrides.
# These run from the Moodle checkout on the host, not in the web container.
# PHPUNIT_BIN="vendor/bin/phpunit"
# PHPCS_BIN="phpcs"
# PHPCBF_BIN="phpcbf"

# Optional PHPCS standard override. The default is the installed lowercase
# Moodle standard name used in this environment.
# PHPCS_STANDARD="moodle"
# PHPCS_STANDARD="moodle-extra"

# Optional install defaults used by ./bin/install
# SITE_FULLNAME="Moodle Master"
# SITE_SHORTNAME="docker_moodle"
# SITE_SUMMARY="Moodle dev site"
# MOODLE_ADMIN_USERNAME="admin"
# MOODLE_ADMIN_PASSWORD="test"
# MOODLE_ADMIN_EMAIL="admin@example.com"
#
# Backward-compatible legacy names still work, but prefer the explicit
# MOODLE_ADMIN_* variables for browser login and install consistency.
# ADMIN_USER="admin"
# ADMIN_PASS="test"
# ADMIN_EMAIL="admin@example.com"

# Optional feature smoke defaults used by ./bin/feature-smoke
# FEATURE_SMOKE_PHPUNIT_TARGET="public/lib/tests/check_test.php"
# FEATURE_SMOKE_BEHAT_TAGS="@core_cache&&~@javascript"
